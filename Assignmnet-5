/*1.	Write a C program to create a binary tree using an array. The program should support the following operations: 
(i)	Insert elements into the tree.
(ii)	Display the tree elements.
(iii)	Display the parent, left child, and right child of a given node.
*/

#include <stdio.h>

#define MAX 100

int tree[MAX];

// Initialize tree with -1 (means empty)
void initTree() {
    for (int i = 0; i < MAX; i++) {
        tree[i] = -1;
    }
}

// Insert element
void insert(int value, int index) {
    if (index >= MAX) {
        printf("Index out of range\n");
        return;
    }

    tree[index] = value;
}

// Display tree (array form)
void display() {
    printf("\nTree elements (index : value):\n");
    for (int i = 0; i < MAX; i++) {
        if (tree[i] != -1) {
            printf("%d : %d\n", i, tree[i]);
        }
    }
}

// Show parent, left child, right child
void showRelations(int index) {
    if (tree[index] == -1) {
        printf("Node does not exist\n");
        return;
    }

    printf("\nNode value: %d\n", tree[index]);

    // Parent
    if (index == 0) {
        printf("Parent: None (Root node)\n");
    } else {
        printf("Parent: %d\n", tree[(index - 1) / 2]);
    }

    // Left Child
    if (2 * index + 1 < MAX && tree[2 * index + 1] != -1) {
        printf("Left Child: %d\n", tree[2 * index + 1]);
    } else {
        printf("Left Child: None\n");
    }

    // Right Child
    if (2 * index + 2 < MAX && tree[2 * index + 2] != -1) {
        printf("Right Child: %d\n", tree[2 * index + 2]);
    } else {
        printf("Right Child: None\n");
    }
}

// Main function
int main() {
    int choice, value, index;

    initTree();

    while (1) {
        printf("\n--- Binary Tree Menu ---\n");
        printf("1. Insert element\n");
        printf("2. Display tree\n");
        printf("3. Show relations\n");
        printf("4. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                printf("Enter value: ");
                scanf("%d", &value);
                printf("Enter index (position in array): ");
                scanf("%d", &index);

                insert(value, index);
                break;

            case 2:
                display();
                break;

            case 3:
                printf("Enter index of node: ");
                scanf("%d", &index);

                showRelations(index);
                break;

            case 4:
                return 0;

            default:
                printf("Invalid choice\n");
        }
    }
}





/*2.	Write a C program to create a binary tree using linked list representation and perform various operations on it.
(i)	Insert nodes into the tree (use user input).
(ii)	Create separate functions to count.
•	Total number of nodes.
•	Number of leaf nodes (nodes with no children).
•	Height of the binary tree.
*/

#include <stdio.h>
#include <stdlib.h>

// Structure of node
struct node {
    int data;
    struct node* left;
    struct node* right;
};

// Create new node
struct node* createNode(int data) {
    struct node* newNode = (struct node*)malloc(sizeof(struct node));
    newNode->data = data;
    newNode->left = newNode->right = NULL;
    return newNode;
}

// Insert node (level-wise using queue concept - simple recursion style)
struct node* insert(struct node* root, int data) {
    if (root == NULL) {
        return createNode(data);
    }

    char choice;
    printf("Insert %d to left or right of %d? (l/r): ", data, root->data);
    scanf(" %c", &choice);

    if (choice == 'l') {
        root->left = insert(root->left, data);
    } else {
        root->right = insert(root->right, data);
    }

    return root;
}

// Count total nodes
int countNodes(struct node* root) {
    if (root == NULL)
        return 0;

    return 1 + countNodes(root->left) + countNodes(root->right);
}

// Count leaf nodes
int countLeafNodes(struct node* root) {
    if (root == NULL)
        return 0;

    if (root->left == NULL && root->right == NULL)
        return 1;

    return countLeafNodes(root->left) + countLeafNodes(root->right);
}

// Find height of tree
int height(struct node* root) {
    if (root == NULL)
        return -1;  // height in terms of edges

    int leftH = height(root->left);
    int rightH = height(root->right);

    return (leftH > rightH ? leftH : rightH) + 1;
}

// Inorder display
void inorder(struct node* root) {
    if (root != NULL) {
        inorder(root->left);
        printf("%d ", root->data);
        inorder(root->right);
    }
}

// Main
int main() {
    struct node* root = NULL;
    int n, data;

    printf("Enter number of nodes: ");
    scanf("%d", &n);

    for (int i = 0; i < n; i++) {
        printf("Enter value: ");
        scanf("%d", &data);

        root = insert(root, data);
    }

    printf("\nInorder Traversal: ");
    inorder(root);

    printf("\nTotal nodes: %d", countNodes(root));
    printf("\nLeaf nodes: %d", countLeafNodes(root));
    printf("\nHeight of tree: %d\n", height(root));

    return 0;
}





/*3.	Write a C program to implement recursive tree traversals on a binary tree. Your program should perform the following traversal functions:
(i)	Inorder traversal (Left → Root → Right).
(ii)	Preorder traversal (Root → Left → Right).
(iii)	 Postorder traversal (Left → Right → Root).
*/

#include <stdio.h>
#include <stdlib.h>

// Node structure
struct node {
    int data;
    struct node* left;
    struct node* right;
};

// Create new node
struct node* createNode(int data) {
    struct node* newNode = (struct node*)malloc(sizeof(struct node));
    newNode->data = data;
    newNode->left = newNode->right = NULL;
    return newNode;
}

// Insert (simple user-based insertion)
struct node* insert(struct node* root, int data) {
    if (root == NULL)
        return createNode(data);

    char choice;
    printf("Insert %d to left or right of %d? (l/r): ", data, root->data);
    scanf(" %c", &choice);

    if (choice == 'l')
        root->left = insert(root->left, data);
    else
        root->right = insert(root->right, data);

    return root;
}

// Inorder Traversal (L → R → R)
void inorder(struct node* root) {
    if (root != NULL) {
        inorder(root->left);
        printf("%d ", root->data);
        inorder(root->right);
    }
}

// Preorder Traversal (R → L → R)
void preorder(struct node* root) {
    if (root != NULL) {
        printf("%d ", root->data);
        preorder(root->left);
        preorder(root->right);
    }
}

// Postorder Traversal (L → R → R)
void postorder(struct node* root) {
    if (root != NULL) {
        postorder(root->left);
        postorder(root->right);
        printf("%d ", root->data);
    }
}

// Main function
int main() {
    struct node* root = NULL;
    int n, data;

    printf("Enter number of nodes: ");
    scanf("%d", &n);

    for (int i = 0; i < n; i++) {
        printf("Enter value: ");
        scanf("%d", &data);

        root = insert(root, data);
    }

    printf("\nInorder Traversal: ");
    inorder(root);

    printf("\nPreorder Traversal: ");
    preorder(root);

    printf("\nPostorder Traversal: ");
    postorder(root);

    return 0;
}





/*4.	Write a C program to perform Level Order Traversal on a binary tree using a queue.*/

#include <stdio.h>
#include <stdlib.h>

#define MAX 100

// Node structure
struct node {
    int data;
    struct node* left;
    struct node* right;
};

// Queue for level order
struct node* queue[MAX];
int front = -1, rear = -1;

// Create new node
struct node* createNode(int data) {
    struct node* newNode = (struct node*)malloc(sizeof(struct node));
    newNode->data = data;
    newNode->left = newNode->right = NULL;
    return newNode;
}

// Enqueue
void enqueue(struct node* temp) {
    if (rear == MAX - 1) {
        printf("Queue Overflow\n");
        return;
    }
    if (front == -1)
        front = 0;

    queue[++rear] = temp;
}

// Dequeue
struct node* dequeue() {
    if (front == -1 || front > rear) {
        return NULL;
    }
    return queue[front++];
}

// Insert (user choice)
struct node* insert(struct node* root, int data) {
    if (root == NULL)
        return createNode(data);

    char choice;
    printf("Insert %d to left or right of %d? (l/r): ", data, root->data);
    scanf(" %c", &choice);

    if (choice == 'l')
        root->left = insert(root->left, data);
    else
        root->right = insert(root->right, data);

    return root;
}

// Level Order Traversal
void levelOrder(struct node* root) {
    if (root == NULL)
        return;

    enqueue(root);

    while (front <= rear) {
        struct node* temp = dequeue();

        printf("%d ", temp->data);

        if (temp->left != NULL)
            enqueue(temp->left);

        if (temp->right != NULL)
            enqueue(temp->right);
    }
}

// Main
int main() {
    struct node* root = NULL;
    int n, data;

    printf("Enter number of nodes: ");
    scanf("%d", &n);

    for (int i = 0; i < n; i++) {
        printf("Enter value: ");
        scanf("%d", &data);

        root = insert(root, data);
    }

    printf("\nLevel Order Traversal: ");
    levelOrder(root);

    return 0;
}





/*5. Write a C program to implement non-recursive tree traversals of a binary tree using a stack. Your program 
should implement the following traversals using the stack: 
(i) Inorder traversal (Left → Root → Right). 
(ii) Preorder traversal (Root → Left → Right).
*/

#include <stdio.h>
#include <stdlib.h>

#define MAX 100

// Node structure
struct node {
    int data;
    struct node* left;
    struct node* right;
};

// Stack
struct node* stack[MAX];
int top = -1;

// Stack operations
void push(struct node* x) {
    stack[++top] = x;
}

struct node* pop() {
    return stack[top--];
}

int isEmpty() {
    return top == -1;
}

// Create node
struct node* createNode(int data) {
    struct node* newNode = (struct node*)malloc(sizeof(struct node));
    newNode->data = data;
    newNode->left = newNode->right = NULL;
    return newNode;
}

// Insert (user choice)
struct node* insert(struct node* root, int data) {
    if (root == NULL)
        return createNode(data);

    char choice;
    printf("Insert %d to left or right of %d? (l/r): ", data, root->data);
    scanf(" %c", &choice);

    if (choice == 'l')
        root->left = insert(root->left, data);
    else
        root->right = insert(root->right, data);

    return root;
}

// Non-recursive Inorder (L → Root → R)
void inorder(struct node* root) {
    struct node* current = root;

    while (current != NULL || !isEmpty()) {

        // Go to leftmost node
        while (current != NULL) {
            push(current);
            current = current->left;
        }

        current = pop();
        printf("%d ", current->data);

        current = current->right;
    }
}

// Non-recursive Preorder (Root → L → R)
void preorder(struct node* root) {
    if (root == NULL)
        return;

    push(root);

    while (!isEmpty()) {
        struct node* current = pop();

        printf("%d ", current->data);

        // Push right first so left is processed first
        if (current->right != NULL)
            push(current->right);

        if (current->left != NULL)
            push(current->left);
    }
}

// Main
int main() {
    struct node* root = NULL;
    int n, data;

    printf("Enter number of nodes: ");
    scanf("%d", &n);

    for (int i = 0; i < n; i++) {
        printf("Enter value: ");
        scanf("%d", &data);

        root = insert(root, data);
    }

    printf("\nInorder Traversal (Non-Recursive): ");
    inorder(root);

    printf("\nPreorder Traversal (Non-Recursive): ");
    preorder(root);

    return 0;
}
